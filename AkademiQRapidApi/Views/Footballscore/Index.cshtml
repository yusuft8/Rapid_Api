@model AkademiQRapidApi.Models.FootballscoreViewModel.Rootobject

@{
    ViewData["Title"] = "Canlı Maçlar";
    var live = Model?.response?.live ?? Array.Empty<AkademiQRapidApi.Models.FootballscoreViewModel.Live>();
    int totalMatches = live.Length;
    int ongoingCount = live.Count(m => m.status?.ongoing == true);
    int finishedCount = live.Count(m => m.status?.finished == true);
    int cancelledCount = live.Count(m => m.status?.cancelled == true);
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Canlı Maçlar</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #08090d;
            --surface: #0f1117;
            --surface2: #161820;
            --border: rgba(255,255,255,0.07);
            --border2: rgba(255,255,255,0.12);
            --live: #ff3d3d;
            --live-glow: rgba(255,61,61,0.18);
            --accent: #4f8eff;
            --accent2: #7eb3ff;
            --green: #2ee89a;
            --yellow: #f5c842;
            --muted: #545870;
            --text: #e8eaf5;
            --text2: #9ea3bf;
            --radius: 16px;
            --radius-sm: 10px;
        }

        body {
            background: var(--bg);
            font-family: 'DM Sans', sans-serif;
            color: var(--text);
            min-height: 100vh;
            padding-bottom: 60px;
        }

        /* HEADER */
        .header {
            padding: 40px 44px 32px;
            display: flex;
            align-items: flex-end;
            gap: 28px;
            border-bottom: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }

            .header::before {
                content: '';
                position: absolute;
                top: -60px;
                left: -60px;
                width: 320px;
                height: 320px;
                background: radial-gradient(circle, rgba(79,142,255,0.07) 0%, transparent 70%);
                pointer-events: none;
            }

        .header-left {
            flex: 1;
        }

        .live-dot-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .live-pulse {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--live);
            box-shadow: 0 0 0 0 rgba(255,61,61,0.6);
            animation: pulse 1.6s ease-out infinite;
        }

        @@keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(255,61,61,0.6);
            }

            70% {
                box-shadow: 0 0 0 8px rgba(255,61,61,0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(255,61,61,0);
            }
        }

        .live-label {
            font-family: 'Syne', sans-serif;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--live);
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 2.6rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            line-height: 1;
            color: var(--text);
        }

        .page-sub {
            font-size: 0.82rem;
            color: var(--muted);
            margin-top: 8px;
            letter-spacing: 0.02em;
        }

        .stat-chips {
            display: flex;
            flex-direction: column;
            gap: 8px;
            align-items: flex-end;
        }

        .chip-row {
            display: flex;
            gap: 8px;
        }

        .chip {
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.04em;
            border: 1px solid var(--border2);
            background: var(--surface);
            color: var(--text2);
            white-space: nowrap;
        }

            .chip.live-chip {
                border-color: rgba(255,61,61,0.4);
                background: var(--live-glow);
                color: var(--live);
            }

            .chip.done-chip {
                border-color: rgba(46,232,154,0.3);
                background: rgba(46,232,154,0.07);
                color: var(--green);
            }

            .chip.total-chip {
                border-color: rgba(79,142,255,0.3);
                background: rgba(79,142,255,0.07);
                color: var(--accent2);
            }

        /* SUMMARY BAR */
        .summary-bar {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            margin: 28px 44px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .s-cell {
            padding: 18px 24px;
            border-right: 1px solid var(--border);
        }

            .s-cell:last-child {
                border-right: none;
            }

        .s-label {
            font-size: 0.68rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-bottom: 8px;
        }

        .s-val {
            font-family: 'Syne', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

            .s-val.red {
                color: var(--live);
            }

            .s-val.green {
                color: var(--green);
            }

            .s-val.yellow {
                color: var(--yellow);
            }

            .s-val.blue {
                color: var(--accent2);
            }

        /* MATCH GRID */
        .match-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 14px;
            padding: 0 44px;
        }

        /* MATCH CARD */
        .match-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            transition: border-color 0.2s, transform 0.15s;
            position: relative;
        }

            .match-card:hover {
                border-color: var(--border2);
                transform: translateY(-2px);
            }

            .match-card.ongoing {
                border-color: rgba(255,61,61,0.25);
            }

        .card-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            padding: 10px 16px;
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.67rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 3px 9px;
            border-radius: 50px;
            flex-shrink: 0;
        }

            .status-badge.ongoing {
                background: var(--live-glow);
                color: var(--live);
                border: 1px solid rgba(255,61,61,0.3);
            }

            .status-badge.finished {
                background: rgba(46,232,154,0.08);
                color: var(--green);
                border: 1px solid rgba(46,232,154,0.2);
            }

            .status-badge.upcoming {
                background: rgba(79,142,255,0.08);
                color: var(--accent2);
                border: 1px solid rgba(79,142,255,0.2);
            }

            .status-badge.cancelled {
                background: rgba(245,200,66,0.08);
                color: var(--yellow);
                border: 1px solid rgba(245,200,66,0.2);
            }

            .status-badge .dot {
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background: currentColor;
            }

            .status-badge.ongoing .dot {
                animation: pulse 1.4s ease-out infinite;
                box-shadow: none;
            }

        .match-time-tag {
            font-size: 0.72rem;
            color: var(--muted);
            letter-spacing: 0.04em;
        }

        .tournament-tag {
            font-size: 0.67rem;
            color: var(--muted);
            background: rgba(255,255,255,0.04);
            padding: 2px 8px;
            border-radius: 4px;
            letter-spacing: 0.03em;
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .score-section {
            padding: 22px 20px 16px;
        }

        .score-row {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .team-block {
            flex: 1;
            min-width: 0;
        }

            .team-block.away {
                text-align: right;
            }

        .team-short {
            font-family: 'Syne', sans-serif;
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: var(--text);
        }

        .team-long {
            font-size: 0.68rem;
            color: var(--muted);
            margin-top: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .red-card-row {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-top: 6px;
        }

        .team-block.away .red-card-row {
            justify-content: flex-end;
        }

        .rc-icon {
            width: 11px;
            height: 14px;
            background: var(--live);
            border-radius: 2px;
            display: inline-block;
        }

        .rc-count {
            font-size: 0.68rem;
            font-weight: 600;
            color: var(--live);
        }

        .score-box {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

        .score-nums {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .score-num {
            font-family: 'Syne', sans-serif;
            font-size: 2.2rem;
            font-weight: 800;
            line-height: 1;
            min-width: 38px;
            text-align: center;
            color: var(--text);
        }

        .score-sep {
            font-family: 'Syne', sans-serif;
            font-size: 1.8rem;
            font-weight: 400;
            color: var(--muted);
            line-height: 1;
        }

        .live-min {
            font-family: 'Syne', sans-serif;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            color: var(--live);
            text-transform: uppercase;
        }

        .score-str {
            font-size: 0.68rem;
            color: var(--muted);
        }

        .card-footer {
            padding: 10px 16px 14px;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .meta-pill {
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.06em;
            color: var(--muted);
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            padding: 3px 9px;
            border-radius: 50px;
        }

        .time-pill {
            margin-left: auto;
            font-size: 0.65rem;
            color: var(--muted);
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            padding: 3px 8px;
            border-radius: 4px;
            letter-spacing: 0.04em;
        }

        /* EMPTY */
        .empty {
            text-align: center;
            padding: 80px 40px;
            color: var(--muted);
        }

            .empty h2 {
                font-family: 'Syne', sans-serif;
                font-size: 1.2rem;
                font-weight: 700;
                margin-bottom: 8px;
                color: var(--text2);
            }

            .empty p {
                font-size: 0.85rem;
            }

        @@media (max-width: 768px) {
            .header {
                padding: 28px 20px 24px;
                flex-wrap: wrap;
            }

            .stat-chips {
                align-items: flex-start;
                margin-top: 12px;
                width: 100%;
            }

            .summary-bar {
                margin: 20px;
                grid-template-columns: repeat(2, 1fr);
            }

            .s-cell:nth-child(2) {
                border-right: none;
            }

            .s-cell:nth-child(3) {
                border-top: 1px solid var(--border);
            }

            .s-cell:nth-child(4) {
                border-top: 1px solid var(--border);
                border-right: none;
            }

            .match-grid {
                padding: 0 20px;
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <header class="header">
        <div class="header-left">
            <div class="live-dot-row">
                <span class="live-pulse"></span>
                <span class="live-label">Canlı Veri</span>
            </div>
            <h1 class="page-title">Canlı Maçlar</h1>
            <p class="page-sub">Football Live API · Anlık Sonuçlar</p>
        </div>
        <div class="stat-chips">
            <div class="chip-row">
                @if (ongoingCount > 0)
                {
                    <span class="chip live-chip">● @ongoingCount Canlı</span>
                }
                @if (finishedCount > 0)
                {
                    <span class="chip done-chip">✓ @finishedCount Bitti</span>
                }
            </div>
            <div class="chip-row">
                <span class="chip total-chip">@totalMatches Toplam Maç</span>
            </div>
        </div>
    </header>

    <div class="summary-bar">
        <div class="s-cell">
            <div class="s-label">Oynanan</div>
            <div class="s-val red">@ongoingCount</div>
        </div>
        <div class="s-cell">
            <div class="s-label">Tamamlanan</div>
            <div class="s-val green">@finishedCount</div>
        </div>
        <div class="s-cell">
            <div class="s-label">İptal</div>
            <div class="s-val yellow">@cancelledCount</div>
        </div>
        <div class="s-cell">
            <div class="s-label">Toplam</div>
            <div class="s-val blue">@totalMatches</div>
        </div>
    </div>

    @if (!live.Any())
    {
        <div class="empty">
            <h2>Şu an canlı maç yok</h2>
            <p>API'den veri alınamadı veya aktif maç bulunmuyor.</p>
        </div>
    }
    else
    {
        <div class="match-grid">
            @foreach (var m in live)
            {
                var st = m.status;
                bool isOngoing = st?.ongoing == true;
                bool isFinished = st?.finished == true;
                bool isCancelled = st?.cancelled == true;

                string statusLabel = isOngoing ? "Canlı"
                : isFinished ? "Bitti"
                : isCancelled ? "İptal"
                : "Başlamadı";

                string statusClass = isOngoing ? "ongoing"
                : isFinished ? "finished"
                : isCancelled ? "cancelled"
                : "upcoming";

                string liveMin = st?.liveTime?._short ?? m.time ?? "";

                <div class="match-card @(isOngoing ? "ongoing" : "")">

                    <div class="card-bar">
                        <span class="status-badge @statusClass">
                            <span class="dot"></span>
                            @statusLabel
                        </span>
                        @if (!string.IsNullOrEmpty(liveMin))
                        {
                            <span class="match-time-tag">@liveMin'</span>
                        }
                        @if (!string.IsNullOrEmpty(m.tournamentStage))
                        {
                            <span class="tournament-tag">@m.tournamentStage</span>
                        }
                    </div>

                    <div class="score-section">
                        <div class="score-row">

                            <div class="team-block home">
                                <div class="team-short">@(m.home?.name ?? "?")</div>
                                @if (!string.IsNullOrEmpty(m.home?.longName) && m.home.longName != m.home.name)
                                {
                                    <div class="team-long">@m.home.longName</div>
                                }
                                @if (m.home?.redCards > 0)
                                {
                                    <div class="red-card-row">
                                        @for (int r = 0; r < m.home.redCards; r++)
                                        {
                                            <span class="rc-icon"></span>
                                        }
                                        <span class="rc-count">@m.home.redCards</span>
                                    </div>
                                }
                            </div>

                            <div class="score-box">
                                @if (isOngoing && !string.IsNullOrEmpty(liveMin))
                                {
                                    <div class="live-min">@liveMin'</div>
                                }
                                <div class="score-nums">
                                    <span class="score-num">@(m.home?.score ?? 0)</span>
                                    <span class="score-sep">–</span>
                                    <span class="score-num">@(m.away?.score ?? 0)</span>
                                </div>
                                @if (!string.IsNullOrEmpty(st?.scoreStr))
                                {
                                    <div class="score-str">@st.scoreStr</div>
                                }
                            </div>

                            <div class="team-block away">
                                <div class="team-short">@(m.away?.name ?? "?")</div>
                                @if (!string.IsNullOrEmpty(m.away?.longName) && m.away.longName != m.away.name)
                                {
                                    <div class="team-long">@m.away.longName</div>
                                }
                                @if (m.away?.redCards > 0)
                                {
                                    <div class="red-card-row" style="justify-content:flex-end;">
                                        <span class="rc-count">@m.away.redCards</span>
                                        @for (int r = 0; r < m.away.redCards; r++)
                                        {
                                            <span class="rc-icon"></span>
                                        }
                                    </div>
                                }
                            </div>

                        </div>
                    </div>

                    <div class="card-footer">
                        @if (st?.periodLength > 0)
                        {
                            <span class="meta-pill">@st.periodLength dk</span>
                        }
                        @if (!string.IsNullOrEmpty(st?.liveTime?.longKey))
                        {
                            <span class="meta-pill">@st.liveTime.longKey</span>
                        }
                        @if (!string.IsNullOrEmpty(st?.aggregatedStr))
                        {
                            <span class="meta-pill">Agg: @st.aggregatedStr</span>
                        }
                        @if (st?.utcTime != default)
                        {
                            <span class="time-pill">@st.utcTime.ToString("HH:mm")</span>
                        }
                    </div>

                </div>
            }
        </div>
    }

</body>
</html>
