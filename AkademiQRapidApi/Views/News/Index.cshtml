@model AkademiQRapidApi.Models.NewsViewModel.Rootobject

@{
    ViewData["Title"] = "Güncel Haberler";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Türkiye Gündemi - Haberler</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0d0f14;
            color: #e8eaf6;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 40px 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .page-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 40px;
            background: linear-gradient(90deg, #60a5fa, #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
        }

        .news-card {
            background: #181c26;
            border: 1px solid #2a2f42;
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .news-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
                border-color: #60a5fa;
            }

        .news-image-container {
            width: 100%;
            height: 200px;
            background-color: #131625;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .news-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .no-image {
            color: #4a5078;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .news-content {
            padding: 20px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .news-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
            color: #8892b0;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .news-source {
            background-color: rgba(96, 165, 250, 0.15);
            color: #60a5fa;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
        }

        .news-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin: 0 0 12px 0;
            line-height: 1.4;
            color: #ffffff;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .news-desc {
            color: #a1a1aa;
            font-size: 0.95rem;
            line-height: 1.5;
            margin: 0 0 20px 0;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
            flex: 1;
        }

        .read-more-btn {
            display: inline-block;
            background-color: transparent;
            color: #c084fc;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: color 0.2s;
            align-self: flex-start;
        }

            .read-more-btn:hover {
                color: #d8b4fe;
                text-decoration: underline;
            }

        .empty-state {
            text-align: center;
            padding: 50px;
            color: #8892b0;
            font-size: 1.2rem;
            background: #181c26;
            border-radius: 16px;
            border: 1px dashed #2a2f42;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1 class="page-title">📰 Türkiye Gündemi</h1>

        @if (Model != null && Model.items != null && Model.items.Any())
        {
            <div class="news-grid">
                @foreach (var news in Model.items)
                {
                    <div class="news-card">

                        <div class="news-image-container">
                            @if (news.images != null && !string.IsNullOrEmpty(news.images.thumbnail))
                            {
                                <img src="@news.images.thumbnail" alt="@news.title" class="news-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                <div class="no-image" style="display:none;">Görsel Yüklenemedi</div>
                            }
                            else
                            {
                                <div class="no-image">Görsel Bulunmuyor</div>
                            }
                        </div>

                        <div class="news-content">
                            <div class="news-meta">
                                <span class="news-source">@(string.IsNullOrEmpty(news.publisher) ? "Bilinmeyen Kaynak" : news.publisher)</span>

                                @if (!string.IsNullOrEmpty(news.timestamp))
                                {
                                    <span class="news-date">@news.timestamp</span>
                                }
                            </div>

                            <h3 class="news-title">@news.title</h3>

                            <p class="news-desc">
                                @(string.IsNullOrEmpty(news.snippet) ? "Bu haber için bir özet bulunmuyor. Detaylar için habere gidin." : news.snippet)
                            </p>

                            <a href="@news.newsUrl" target="_blank" class="read-more-btn">Haberi Oku ➔</a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                Şu anda gösterilecek haber bulunamadı veya bir hata oluştu.
            </div>
        }
    </div>

</body>
</html>