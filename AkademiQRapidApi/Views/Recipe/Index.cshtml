@model AkademiQRapidApi.Models.RecipeViewModel.Rootobject
@{
    ViewData["Title"] = "Günün Tarifi";
    Layout = null;
    var today = DateTime.Now;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ChefLog | Günün Tarifi</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@300;400;600&family=IBM+Plex+Sans:wght@300;400;600&display=swap" rel="stylesheet" />
    <style>
        /* Paylaştığınız mevcut CSS stilleri buraya gelecek (Aynen koruyabilirsiniz) */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #05060d;
            color: #e8ecff;
            font-family: 'IBM Plex Sans', sans-serif;
            min-height: 100vh;
            padding: 40px 16px;
        }

        .wrapper {
            max-width: 900px;
            margin: 0 auto;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 32px;
        }

        .brand-name {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 36px;
            letter-spacing: .06em;
        }

        .brand-sub {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 10px;
            color: #4a5078;
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        .live-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(16,185,129,.1);
            border: 1px solid rgba(16,185,129,.3);
            padding: 6px 14px;
            border-radius: 6px;
            font-family: 'IBM Plex Mono', monospace;
            font-size: 10px;
            color: #34d399;
            letter-spacing: .1em;
            text-transform: uppercase;
        }

        .live-dot {
            width: 7px;
            height: 7px;
            background: #34d399;
            border-radius: 50%;
            animation: blink 1.6s ease-in-out infinite;
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1
            }

            50% {
                opacity: .2
            }
        }

        .sec-label {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 10px;
            color: #4a5078;
            letter-spacing: .14em;
            text-transform: uppercase;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .sec-label::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #1e2236;
            }

        .hero-card {
            background: #0d0f1a;
            border: 1px solid #1e2236;
            border-radius: 14px;
            overflow: hidden;
            margin-bottom: 20px;
            position: relative;
        }

        .hero-poster {
            width: 100%;
            height: 350px;
            object-fit: cover;
            display: block;
            opacity: .9;
        }

        .hero-body {
            padding: 22px 26px;
        }

        .recipe-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 42px;
            color: #e8ecff;
            margin-bottom: 16px;
            line-height: 1;
        }

        .pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 18px;
        }

        .pill {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 10px;
            color: #8892b0;
            border: 1px solid #1e2236;
            padding: 4px 10px;
            border-radius: 6px;
        }

            .pill.gold {
                color: #fbbf24;
                border-color: rgba(251,191,36,.3);
            }

            .pill.green {
                color: #34d399;
                border-color: rgba(16,185,129,.3);
            }

        .stats-bar {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            border-top: 1px solid #1e2236;
            padding-top: 18px;
        }

        .stat {
            text-align: center;
        }

            .stat + .stat {
                border-left: 1px solid #1e2236;
            }

        .stat-val {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 28px;
            color: #e8ecff;
        }

        .stat-lbl {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 9px;
            color: #4a5078;
        }

        .two-col {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        .panel {
            background: #0d0f1a;
            border: 1px solid #1e2236;
            border-radius: 12px;
            padding: 18px 20px;
        }

        .panel-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 18px;
            color: #e8ecff;
            border-bottom: 1px solid #1e2236;
            margin-bottom: 12px;
            padding-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .ingredient-list {
            list-style: none;
        }

            .ingredient-list li {
                display: flex;
                justify-content: space-between;
                padding: 8px 0;
                border-bottom: 1px dashed #1e2236;
                font-size: 13px;
            }

        .diet-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .diet-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px;
            border-radius: 6px;
            font-size: 11px;
            font-family: 'IBM Plex Mono', monospace;
            border: 1px solid transparent;
        }

            .diet-badge.yes {
                background: rgba(16,185,129,0.05);
                border-color: rgba(16,185,129,0.2);
                color: #34d399;
            }

            .diet-badge.no {
                background: rgba(255,255,255,0.02);
                border-color: #1e2236;
                color: #4a5078;
            }

        .steps-panel {
            background: #0d0f1a;
            border: 1px solid #1e2236;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 30px;
        }

        .steps-list {
            list-style: none;
            counter-reset: my-counter;
        }

            .steps-list li {
                counter-increment: my-counter;
                display: flex;
                gap: 20px;
                margin-bottom: 20px;
                color: #c4c9e8;
                line-height: 1.6;
            }

                .steps-list li::before {
                    content: counter(my-counter);
                    font-family: 'Bebas Neue', sans-serif;
                    font-size: 24px;
                    color: #34d399;
                }

        .footer {
            display: flex;
            justify-content: space-between;
            color: #4a5078;
            font-family: 'IBM Plex Mono', monospace;
            font-size: 10px;
            border-top: 1px solid #1e2236;
            padding-top: 20px;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="topbar">
            <div>
                <div class="brand-name">ChefLog</div>
                <div class="brand-sub">Günün Tarifi · @today.ToString("dd MMMM yyyy")</div>
            </div>
            <div class="live-badge">
                <div class="live-dot"></div> Güncel
            </div>
        </div>

        @if (Model?.recipes != null && Model.recipes.Any())
        {
            @foreach (var recipe in Model.recipes)
            {
                <div class="sec-label">Bugünün Öne Çıkanı</div>
                <div class="hero-card">
                    @if (!string.IsNullOrEmpty(recipe.image))
                    {
                        <img src="@recipe.image" alt="@recipe.title" class="hero-poster" />
                    }
                    else
                    {
                        <div class="hero-poster-placeholder">🍳</div>
                    }

                    <div class="hero-body">
                        <div class="recipe-title">@recipe.title</div>
                        <div class="pills">
                            <span class="pill gold">⏱ @recipe.readyInMinutes DK</span>
                            <span class="pill">👤 @recipe.servings PORSİYON</span>
                            @if (recipe.veryHealthy)
                            {
                                <span class="pill green">✦ ÇOK SAĞLIKLI</span>
                            }
                            @if (recipe.vegetarian)
                            {
                                <span class="pill green">VEJETARYEN</span>
                            }
                        </div>

                        <div class="stats-bar">
                            <div class="stat">
                                <div class="stat-val">@recipe.healthScore</div>
                                <div class="stat-lbl">SAĞLIK PUANI</div>
                            </div>
                            <div class="stat">
                                <div class="stat-val">@recipe.aggregateLikes</div>
                                <div class="stat-lbl">BEĞENİ</div>
                            </div>
                            <div class="stat">
                                <div class="stat-val">₺@((recipe.pricePerServing / 10).ToString("0.00"))</div>
                                <div class="stat-lbl">PORSİYON MALİYETİ</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="two-col">
                    <div class="panel">
                        <div class="panel-title">Malzemeler</div>
                        <ul class="ingredient-list">
                            @foreach (var ing in recipe.extendedIngredients)
                            {
                                <li>
                                    <span style="color: #c4c9e8;">@ing.name</span>
                                    <span style="color: #fbbf24; font-family: 'IBM Plex Mono';">@ing.amount.ToString("0.##") @ing.unit</span>
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="panel">
                        <div class="panel-title">Diyet Analizi</div>
                        <div class="diet-grid">
                            <div class="diet-badge @(recipe.vegan ? "yes" : "no")">Vegan</div>
                            <div class="diet-badge @(recipe.glutenFree ? "yes" : "no")">Glutensiz</div>
                            <div class="diet-badge @(recipe.dairyFree ? "yes" : "no")">Sütsüz</div>
                            <div class="diet-badge @(recipe.cheap ? "yes" : "no")">Ekonomik</div>
                        </div>
                        @if (recipe.diets != null && recipe.diets.Any())
                        {
                            <div style="margin-top: 15px; display: flex; flex-wrap: wrap; gap: 5px;">
                                @foreach (var diet in recipe.diets)
                                {
                                    <span class="pill green">@diet.ToUpper()</span>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="sec-label">Hazırlanışı</div>
                <div class="steps-panel">
                    @if (recipe.analyzedInstructions != null && recipe.analyzedInstructions.Any())
                    {
                        <ul class="steps-list">
                            @foreach (var step in recipe.analyzedInstructions[0].steps)
                            {
                                <li>@step.step</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p style="color: #8892b0; line-height: 1.8;">@Html.Raw(recipe.summary)</p>
                    }
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <span class="empty-icon">🍳</span>
                <div class="empty-title">Tarif Bulunamadı</div>
            </div>
        }

        <div class="footer">
            <span>Spoonacular API Data Integrity</span>
            <span>@today.Year · ChefLog Engine</span>
        </div>
    </div>
</body>
</html>