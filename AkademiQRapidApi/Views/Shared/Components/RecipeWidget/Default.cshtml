@model AkademiQRapidApi.Models.RecipeViewModel.Rootobject
@{
    Layout = null;
    // Sadece ilk tarifi veya ilk 3 tarifi almak isteyebilirsiniz.
    // Burada 1 adet "Günün Tarifi" odağında bir widget hazırladım.
    var recipe = Model?.recipes?.FirstOrDefault();
}

<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
    .chef-widget {
        background: #0d0f1a;
        border: 1px solid #1e2236;
        border-radius: 16px;
        width: 320px; /* Standart widget genişliği */
        overflow: hidden;
        font-family: 'IBM Plex Sans', sans-serif;
        position: relative;
        transition: transform 0.3s ease;
    }

        .chef-widget:hover {
            transform: translateY(-5px);
            border-color: #34d399;
        }

    .widget-img-container {
        width: 100%;
        height: 180px;
        position: relative;
    }

    .widget-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .widget-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(5, 6, 13, 0.8);
        backdrop-filter: blur(4px);
        color: #34d399;
        padding: 4px 8px;
        border-radius: 6px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 10px;
        border: 1px solid rgba(52, 211, 153, 0.3);
    }

    .widget-content {
        padding: 16px;
    }

    .widget-category {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 9px;
        color: #4a5078;
        text-transform: uppercase;
        margin-bottom: 8px;
        letter-spacing: 1px;
    }

    .widget-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 24px;
        color: #e8ecff;
        margin-bottom: 12px;
        line-height: 1.2;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .widget-stats {
        display: flex;
        justify-content: space-between;
        border-top: 1px solid #1e2236;
        padding-top: 12px;
        margin-top: 8px;
    }

    .w-stat {
        text-align: center;
    }

    .w-stat-val {
        color: #fbbf24;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 18px;
    }

    .w-stat-lbl {
        color: #4a5078;
        font-size: 8px;
        text-transform: uppercase;
        font-family: 'IBM Plex Mono', monospace;
    }

    .widget-btn {
        display: block;
        width: 100%;
        background: #10b981;
        color: #fff;
        text-align: center;
        padding: 10px;
        text-decoration: none;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 16px;
        letter-spacing: 1px;
        transition: background 0.2s;
    }

        .widget-btn:hover {
            background: #059669;
        }
</style>

@if (recipe != null)
{
    <div class="chef-widget">
        <div class="widget-img-container">
            <img src="@recipe.image" alt="@recipe.title" class="widget-img" />
            <div class="widget-badge">GÜNÜN TARİFİ</div>
        </div>

        <div class="widget-content">
            <div class="widget-category">@(recipe.dishTypes?.FirstOrDefault() ?? "Yemek")</div>
            <h3 class="widget-title">@recipe.title</h3>

            <div class="widget-stats">
                <div class="w-stat">
                    <div class="w-stat-val">@recipe.readyInMinutes dk</div>
                    <div class="w-stat-lbl">SÜRE</div>
                </div>
                <div class="w-stat" style="border-left: 1px solid #1e2236; border-right: 1px solid #1e2236; padding: 0 15px;">
                    <div class="w-stat-val">@recipe.healthScore</div>
                    <div class="w-stat-lbl">PUAN</div>
                </div>
                <div class="w-stat">
                    <div class="w-stat-val">₺@((recipe.pricePerServing / 10).ToString("0"))</div>
                    <div class="w-stat-lbl">MALİYET</div>
                </div>
            </div>
        </div>

        <a href="/Recipe/Details/@recipe.id" class="widget-btn">TARİFİ GÖR</a>
    </div>
}
else
{
    <div class="chef-widget" style="padding: 20px; text-align: center; color: #4a5078;">
        Tarif Yükleniyor...
    </div>
}