@model AkademiQRapidApi.Models.WeatherVievModel.Rootobject

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    .weather-glass-card {
        font-family: 'Inter', sans-serif;
        background: rgba(26, 26, 26, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(0, 255, 255, 0.2);
        border-radius: 12px;
        padding: 24px; /* İç boşluğu biraz artırarak sağdaki karta eşitledim */
        width: 100%; /* SABİT GENİŞLİK KALKTI - Panel ne kadarsa o kadar yayılacak */
        height: 100%; /* Dış kapsayıcının boyuna sığması için */
        box-sizing: border-box;
        color: #ffffff;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        display: flex;
        flex-direction: column;
        justify-content: space-between; /* İçeriklerin dikeyde dengeli dağılması için */
    }

    .weather-widget-header {
        color: #BF00FF;
        font-weight: 700;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .weather-dot {
        width: 8px;
        height: 8px;
        background-color: #00FFFF;
        border-radius: 50%;
        box-shadow: 0 0 8px #00FFFF;
    }

    .weather-main-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
    }

    .weather-big-icon {
        font-size: 48px; /* İkon boyutunu kart büyüdüğü için hafifçe artırdım */
        filter: drop-shadow(0 0 6px rgba(0, 255, 255, 0.3));
    }

    .weather-temp-value {
        font-size: 36px; /* Derece puntosunu büyüttüm */
        font-weight: 700;
        color: #ffffff;
        line-height: 1.1;
    }

    .weather-sub-info {
        font-size: 12px;
        color: #00FFFF;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-top: 4px;
    }

    .weather-divider {
        border: none;
        height: 1px;
        background: linear-gradient(90deg, rgba(191, 0, 255, 0.4), transparent);
        margin-bottom: 20px;
    }

    .weather-details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px; /* Kutuların arasındaki boşluğu açtım */
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin-top: auto; /* Grid'i her zaman en alta yaslar */
    }

    .weather-grid-item {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 12px 16px; /* Kutuların içini daha dolgun yaptım */
        border-radius: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .weather-grid-item strong {
            color: #ffffff;
            font-weight: 600;
        }
</style>

@if (Model != null)
{
    <div class="weather-glass-card">
        <div>
            @* Üst kısmı sarmalayan blok *@
            <div class="weather-widget-header">
                <span class="weather-dot"></span>
                <span>Hava Durumu</span>
            </div>

            <div class="weather-main-section">
                <div class="weather-big-icon">⛅</div>
                <div>
                    <div class="weather-temp-value">
                        @(Model.main != null ? Math.Round(Model.main.temp).ToString() : "0")°C
                    </div>
                    <div class="weather-sub-info">
                        @if (Model.weather != null && Model.weather.Length > 0)
                        {
                            @Model.weather[0].description.ToUpper()
                        }
                        · @Model.name
                    </div>
                </div>
            </div>
        </div>

        <div>
            @* Alt kısmı sarmalayan blok *@
            <hr class="weather-divider">

            <div class="weather-details-grid">
                <div class="weather-grid-item">
                    <span>Nem</span>
                    <strong>%@Model.main?.humidity</strong>
                </div>
                <div class="weather-grid-item">
                    <span>Rüzgar</span>
                    <strong>@Model.wind?.speed km/s</strong>
                </div>
                <div class="weather-grid-item">
                    <span>Min</span>
                    <strong>@(Model.main != null ? Math.Round(Model.main.temp_min).ToString() : "0")°</strong>
                </div>
                <div class="weather-grid-item">
                    <span>Maks</span>
                    <strong>@(Model.main != null ? Math.Round(Model.main.temp_max).ToString() : "0")°</strong>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="weather-glass-card">
        <div class="weather-widget-header">
            <span class="weather-dot" style="background-color: #ff0055; box-shadow: 0 0 8px #ff0055;"></span>
            <span>Hava Durumu</span>
        </div>
        <div style="font-size: 12px; color: rgba(255,255,255,0.4);">Hava durumu bilgisi şu anda yüklenemedi.</div>
    </div>
}