<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — API Panel</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@@400;500;700&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:           #0d0f14;
            --bg2:          #13161e;
            --bg3:          #1a1e2a;
            --card:         #181c26;
            --card-hover:   #1e2333;
            --border:       #2a2f42;
            --border-glow:  #3d4460;
            --accent:       #6c8fff;
            --accent2:      #4ecdc4;
            --accent3:      #ff6b6b;
            --accent4:      #ffd93d;
            --text:         #e8eaf6;
            --text2:        #8892b0;
            --text3:        #4a5268;
            --sidebar-w:    220px;
            --topbar-h:     56px;
            --font-main:    'Syne', sans-serif;
            --font-mono:    'JetBrains Mono', monospace;
        }

        html, body {
            height: 100%;
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-main);
            font-size: 14px;
            line-height: 1.5;
        }

        /* ── LAYOUT SHELL ─────────────────────────── */
        .shell {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ── SIDEBAR ──────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--bg2);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            z-index: 100;
        }

        .sidebar-logo {
            padding: 22px 18px 18px;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-logo .logo-text {
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 0.06em;
            color: var(--text);
        }

        .sidebar-logo .logo-sub {
            font-size: 10px;
            color: var(--text3);
            font-family: var(--font-mono);
            margin-top: 2px;
            letter-spacing: 0.08em;
        }

        .nav-section {
            padding: 18px 0 8px;
        }

        .nav-label {
            font-size: 9px;
            color: var(--text3);
            letter-spacing: 0.14em;
            text-transform: uppercase;
            padding: 0 18px 8px;
            font-family: var(--font-mono);
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 18px;
            cursor: pointer;
            text-decoration: none;
            font-size: 13px;
            color: var(--text2);
            border-left: 2px solid transparent;
            transition: background 0.15s, color 0.15s, border-color 0.15s;
        }

        .nav-item:hover {
            background: var(--bg3);
            color: var(--text);
            border-left-color: var(--border-glow);
        }

        .nav-item.active {
            background: rgba(108, 143, 255, 0.08);
            color: var(--accent);
            border-left-color: var(--accent);
        }

        .nav-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .nav-badge {
            margin-left: auto;
            font-size: 9px;
            font-family: var(--font-mono);
            background: rgba(108, 143, 255, 0.12);
            color: var(--accent);
            padding: 2px 6px;
            border-radius: 4px;
        }

        .nav-badge.warn {
            background: rgba(255, 217, 61, 0.12);
            color: var(--accent4);
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 14px 18px;
            border-top: 1px solid var(--border);
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #34d399;
            display: inline-block;
            margin-right: 6px;
            box-shadow: 0 0 6px #34d39966;
        }

        .status-text {
            font-size: 11px;
            color: var(--text2);
            font-family: var(--font-mono);
        }

        /* ── MAIN COLUMN ──────────────────────────── */
        .main-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* ── TOPBAR ───────────────────────────────── */
        .topbar {
            height: var(--topbar-h);
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .topbar-left h1 {
            font-size: 17px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.2;
        }

        .topbar-left p {
            font-size: 11px;
            color: var(--text3);
            font-family: var(--font-mono);
        }

        .topbar-right {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .chip {
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 4px 12px;
            font-size: 11px;
            color: var(--text2);
            font-family: var(--font-mono);
        }

        .chip.live {
            border-color: rgba(52, 211, 153, 0.3);
            color: #34d399;
        }

        /* ── PAGE CONTENT ─────────────────────────── */
        .page-content {
            flex: 1;
            overflow-y: auto;
            padding: 22px 24px;
            scrollbar-width: thin;
            scrollbar-color: var(--border) transparent;
        }

        .page-content::-webkit-scrollbar { width: 5px; }
        .page-content::-webkit-scrollbar-track { background: transparent; }
        .page-content::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

        /* ── VALIDATION SUMMARY ───────────────────── */
        .validation-summary-errors {
            background: rgba(255, 107, 107, 0.08);
            border: 1px solid rgba(255, 107, 107, 0.3);
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 16px;
            color: var(--accent3);
            font-size: 13px;
        }

        /* ── UTILITY ──────────────────────────────── */
        .text-muted  { color: var(--text2); }
        .text-faint  { color: var(--text3); }
        .mono        { font-family: var(--font-mono); }
        .card-dark {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 16px;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="shell">

    <!-- ── SIDEBAR ── -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-text">API PANEL</div>
            <div class="logo-sub">v2.4.1 — STABLE</div>
        </div>

        <nav>
            <div class="nav-section">
                <div class="nav-label">Servisler</div>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="nav-dot" style="background:#6c8fff;"></span>
                    Genel Bakış
                </a>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Weather" ? "active" : "")"
                   asp-area="" asp-controller="Weather" asp-action="Index">
                    <span class="nav-dot" style="background:#6c8fff;"></span>
                    Hava Durumu
                    <span class="nav-badge">OK</span>
                </a>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Currency" ? "active" : "")"
                   asp-area="" asp-controller="Currency" asp-action="Index">
                    <span class="nav-dot" style="background:#4ecdc4;"></span>
                    Döviz
                    <span class="nav-badge">OK</span>
                </a>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Gas" ? "active" : "")"
                   asp-area="" asp-controller="Gas" asp-action="Index">
                    <span class="nav-dot" style="background:#ffd93d;"></span>
                    Akaryakıt
                    <span class="nav-badge warn">YAVAŞ</span>
                </a>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Football" ? "active" : "")"
                   asp-area="" asp-controller="Football" asp-action="Index">
                    <span class="nav-dot" style="background:#ff6b6b;"></span>
                    Futbol
                    <span class="nav-badge">OK</span>
                </a>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Youtube" ? "active" : "")"
                   asp-area="" asp-controller="Youtube" asp-action="Index">
                    <span class="nav-dot" style="background:#c084fc;"></span>
                    YouTube
                    <span class="nav-badge">OK</span>
                </a>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Recipe" ? "active" : "")"
                   asp-area="" asp-controller="Recipe" asp-action="Index">
                    <span class="nav-dot" style="background:#34d399;"></span>
                    Tarif
                    <span class="nav-badge">OK</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-label">Sistem</div>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Settings" ? "active" : "")"
                   asp-area="" asp-controller="Settings" asp-action="Index">
                    <span class="nav-dot" style="background:#4a5268;"></span>
                    Ayarlar
                </a>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Logs" ? "active" : "")"
                   asp-area="" asp-controller="Logs" asp-action="Index">
                    <span class="nav-dot" style="background:#4a5268;"></span>
                    Loglar
                </a>
            </div>
        </nav>

        <div class="sidebar-footer">
            <div style="margin-bottom:5px;">
                <span class="status-dot"></span>
                <span class="status-text">6/6 aktif</span>
            </div>
            <div style="font-size:10px;color:var(--text3);font-family:var(--font-mono);">
                son güncelleme: @DateTime.Now.ToString("HH:mm:ss")
            </div>
        </div>
    </aside>

    <!-- ── MAIN ── -->
    <div class="main-col">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <h1>@ViewData["Title"]</h1>
                <p>@(ViewData["Subtitle"] ?? "Tüm servislerden canlı veriler")</p>
            </div>
            <div class="topbar-right">
                <div class="chip live">● CANLI</div>
                <div class="chip">30s yenileme</div>
            </div>
        </header>

        <!-- Page body -->
        <main class="page-content">
            @RenderBody()
        </main>

    </div>
</div>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
